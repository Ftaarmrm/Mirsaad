# ============================================
# Database
# ============================================
DATABASE_URL="file:./db/custom.db"

# ============================================
# AI Configuration (Optional)
# ============================================
Z_AI_API_KEY="your-api-key-here"

# ============================================
# Brand Variant
# default | economy | tech | energy
# ============================================
NEXT_PUBLIC_BRAND_VARIANT="default"

# ============================================
# Application
# ============================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"

# ============================================
# Admin Panel (مهم للأمان)
# ============================================
# كلمة مرور للوصول إلى /admin/ads
# غيّرها فوراً في الإنتاج!
ADMIN_PASSWORD="change-me-now-please"

# مفتاح سري لتوقيع sessions (مولّد عشوائياً)
# يمكن توليده عبر: openssl rand -hex 32
ADMIN_SECRET="change-to-random-32-char-string"

# ============================================
# Google AdSense
# ============================================
# Publisher ID من AdSense (مثل: ca-pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""

# ⚠️ ملاحظة: Ad Slot IDs لم تعد تُكوّن هنا
# يتم إدارتها الآن من لوحة الأدمن: /admin/ads

# ============================================
# RSS Fetcher Security (Optional)
# ============================================
# لحماية endpoint جلب الأخبار من التشغيل غير المصرح
FETCH_NEWS_API_KEY=""

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS="http://localhost:3000"
