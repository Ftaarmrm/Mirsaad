# ── Build artifacts ────────────────────────────────────────
.next
node_modules
.turbo

# ── Source control ─────────────────────────────────────────
.git
.gitignore

# ── Environment files (لا ترسل .env الحقيقي) ───────────────
.env
.env.local
.env.*.local
local-*

# ── Local database (لا ترسل قاعدة بيانات التطوير) ──────────
db/
*.db
*.db-shm
*.db-wal

# ── Docker files (غير ضرورية داخل الصورة) ────────────────────
Dockerfile
.dockerignore
docker-compose*.yml

# ── Logs ───────────────────────────────────────────────────
*.log
dev.log
server.log

# ── Lock files (npm يستخدم package-lock.json، bun.lock غير مطلوب في Docker)
bun.lock
yarn.lock
pnpm-lock.yaml

# ── Docs & examples ────────────────────────────────────────
README.md
ARCHITECTURE.md
ADMIN_GUIDE.md
QUICKSTART.md
worklog.md
docs/
examples/
download/

# ── Dev config ─────────────────────────────────────────────
.config/
.local/
.npm/
.npmrc
.wget-hsts
.zscripts/

# ── Tests ──────────────────────────────────────────────────
__tests__/
*.test.ts
*.spec.ts
